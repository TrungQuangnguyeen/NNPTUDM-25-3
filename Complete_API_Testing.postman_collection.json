              "raw": "{\n  \"title\": \"Laptop Dell XPS 13\",\n  \"price\": 1200,\n  \"description\": \"High-performance laptop for professionals\",\n  \"images\": [\"https://i.imgur.com/dell-xps.jpeg\"],\n  \"category\": \"CATEGORY_ID_HERE\"\n}"

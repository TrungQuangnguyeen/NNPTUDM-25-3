    {
      "name": "📊 INVENTORY APIs",
      "item": [
        {
          "name": "Get All Inventories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/v1/inventories",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "inventories"]
            }
          },
          "description": "Lấy tất cả inventories (join with products)"
        },
        {
          "name": "Get Inventory By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/api/v1/inventories/INVENTORY_ID_HERE",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "inventories", "INVENTORY_ID_HERE"]
            }
          },
          "description": "Lấy inventory theo ID (join with product details)"
        },
        {
          "name": "Add Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 50\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/inventories/add-stock",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "inventories", "add-stock"]
            }
          },
          "description": "Tăng stock (stock += quantity)\n\nSau: stock = 0 + 50 = 50"
        },
        {
          "name": "Remove Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 10\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/inventories/remove-stock",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "inventories", "remove-stock"]
            }
          },
          "description": "Giảm stock (stock -= quantity)\n\nSau: stock = 50 - 10 = 40"
        },
        {
          "name": "Reservation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 15\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/inventories/reservation",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "inventories", "reservation"]
            }
          },
          "description": "Đặt hàng (reservation)\n→ stock -= quantity\n→ reserved += quantity\n\nSau: stock = 40 - 15 = 25, reserved = 0 + 15 = 15"
        },
        {
          "name": "Sold",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 15\n}"
            },
            "url": {
              "raw": "http://localhost:3000/api/v1/inventories/sold",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "v1", "inventories", "sold"]
            }
          },
          "description": "Xác nhận bán\n→ reserved -= quantity\n→ soldCount += quantity\n\nSau: reserved = 15 - 15 = 0, soldCount = 0 + 15 = 15"
        }
      ]
    }
  ]
